#--------------------------------------------------------------------
# Production — yasti.site
# Salin ke server: cp deploy/env.production.example .env
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

app.baseURL = 'https://yasti.site/'
app.indexPage =
app.forceGlobalSecureRequests = true
app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE (sesuaikan dengan MySQL di VPS)
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = porto
database.default.username = porto_user
database.default.password = GANTI_PASSWORD_KUAT
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# AI CHAT (opsional)
#--------------------------------------------------------------------

AI_PROVIDER = kimchi
KIMCHI_BASE_URL = https://api.example.com/v1
KIMCHI_API_KEY = isi_api_key_anda
KIMCHI_CHAT_MODEL = kimi2.6
KIMCHI_TIMEOUT = 25
KIMCHI_CONNECT_TIMEOUT = 8
KIMCHI_VERIFY_SSL = true

#--------------------------------------------------------------------
# ENCRYPTION (generate: php spark key:generate)
#--------------------------------------------------------------------

# encryption.key = hex2bin:...
